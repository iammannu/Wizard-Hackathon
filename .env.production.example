# Backend production environment template.
#
# pydantic-settings reads exactly `.env` (see app/core/config.py's
# Config.env_file) — there's no separate ".env.production" loading
# mechanism, so on your host, copy this file's *values* into whatever your
# platform uses to inject environment variables (a real .env file deployed
# alongside the app, your PaaS's env var UI, a secrets manager, etc.).
# This file itself is a reference template, not something the app reads
# directly — never commit a copy of this with real secrets filled in.

ENVIRONMENT=production

# Generate a real random 32+ char secret — never reuse the dev default.
SECRET_KEY=

# Restrict to your real frontend origin(s). Never leave this as "*" once
# real users are hitting this API.
CORS_ALLOWED_ORIGINS=https://app.alphaforage.com

# Market data
POLYGON_API_KEY=
FINNHUB_API_KEY=

# AI inference
OPENAI_API_KEY=

# Sponsor integrations
YOUCOM_API_KEY=
TAVILY_API_KEY=

# SEC EDGAR requires a real, descriptive User-Agent identifying you
# (https://www.sec.gov/os/webmaster-faq#developers) — requests are refused
# without one, not sent with a placeholder.
SEC_EDGAR_USER_AGENT="Your Company your-email@example.com"

# Swap to Postgres for production — SQLite is a single-file, single-writer
# database, not appropriate for a real deployment with concurrent users.
DATABASE_URL=postgresql+asyncpg://user:pass@your-db-host:5432/alphaforage

# Host ports docker-compose.yml publishes the two containers on — change if
# 80/8000 are already bound by another service (e.g. a host-level nginx/Caddy
# doing TLS termination) on your Hostinger VPS.
API_PORT=8000
WEB_PORT=80

# Baked into the frontend image at build time. Leave unset if frontend and
# API are served from the same domain (nginx proxies /api automatically —
# see web/nginx.conf); set only if the API is on a separate subdomain.
# VITE_API_URL=https://api.yourdomain.com
