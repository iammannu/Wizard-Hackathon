# Frontend production environment template.
#
# Vite only bakes VITE_-prefixed vars present at *build* time into the
# output (`pnpm build`) — this isn't read at runtime, so it must be set in
# whatever CI/build environment produces your deployed dist/ bundle, or via
# a `web/.env.production` file (gitignored — copy this template, don't
# commit the real one) that Vite picks up automatically during `vite build`.

# Set this if the frontend is deployed on a different origin than the
# backend API (e.g. a static host + a separately-hosted API). Leave unset
# (or delete the line) if both are served from the same origin behind one
# reverse proxy — window.location.origin is then used automatically, see
# web/src/lib/api.js.
VITE_API_URL=https://api.alphaforage.com
