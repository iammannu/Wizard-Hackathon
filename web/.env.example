# Frontend environment — Vite only exposes vars prefixed VITE_ to client code,
# and only variables present at *build* time are baked into the output
# (see web/src/lib/api.js). Copy this file to .env.local for local overrides,
# or .env.production for a production build.

# Backend API origin. Leave unset to default to window.location.origin
# (correct when the frontend and API are served from the same origin, e.g.
# behind a single reverse proxy). Set explicitly when the API is deployed
# on a different origin than the frontend:
# VITE_API_URL=https://api.alphaforage.com
VITE_API_URL=
