# ── Required ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-min-32-chars

# Market Data
POLYGON_API_KEY=your_polygon_api_key
FINNHUB_API_KEY=your_finnhub_api_key

# AI Inference
OPENAI_API_KEY=your_openai_api_key

# ── Sponsor Integrations ────────────────────────────────────────────────────────
# You.com Web Search API
YOUCOM_API_KEY=your_youcom_api_key

# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key

# ── Document Intelligence (Phase 2) ─────────────────────────────────────────────
# SEC EDGAR — no API key, but requires a compliant User-Agent identifying the
# requester on every request. Format: "App/Company Name contact@example.com"
# https://www.sec.gov/os/webmaster-faq#developers
SEC_EDGAR_USER_AGENT=YourCompany contact@example.com

# ── Optional Database ───────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/alphaforage

# ── Model Configuration ─────────────────────────────────────────────────────────
# DEFAULT_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini

# ── Deployment ──────────────────────────────────────────────────────────────────
# Infrastructure: InsForge
# GPU Inference: Nebius