# ── Required ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-min-32-chars

# Market data (free tier works for both)
POLYGON_API_KEY=your-polygon-api-key
FINNHUB_API_KEY=your-finnhub-api-key

# AI inference
OPENAI_API_KEY=your-openai-api-key

# ── Sponsor Integrations ─────────────────────────────────────────────────────────
# You.com Web Search API — primary research engine
# Get key: https://api.you.com/
YOUCOM_API_KEY=your-youcom-api-key

# Tavily Search API — cross-validation layer
# Get key: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key

# ── Optional Overrides ────────────────────────────────────────────────────────────
# Swap SQLite for Postgres when scaling (replace <host> with your real DB host):
# DATABASE_URL=postgresql+asyncpg://user:pass@<host>:5432/alphaforage

# Switch AI models:
# DEFAULT_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini

# ── CORS (required for production) ────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API from a browser.
# Defaults to "*" for local dev. In production, set this to your real
# frontend origin(s) — a wildcard is not appropriate once real users hit this:
# CORS_ALLOWED_ORIGINS=https://app.alphaforage.com,https://alphaforage.com
CORS_ALLOWED_ORIGINS=*

# ── Docker Compose port overrides (optional) ──────────────────────────────────────
# Host ports docker-compose.yml publishes the two containers on. Change
# these if 80/8000 are already taken on your host.
# API_PORT=8000
# WEB_PORT=80

# Baked into the frontend at build time (docker-compose passes this to
# web/Dockerfile as a build arg) — leave unset for the default same-origin
# deployment where nginx proxies /api to the api container. Set only if the
# frontend and API are hosted on different domains:
# VITE_API_URL=https://api.yourdomain.com

# ── Deployment (InsForge + Nebius) ────────────────────────────────────────────────
# Infrastructure: InsForge handles agent services, API hosting, auth, and DB
# GPU inference: Nebius cluster (future larger reasoning models)
# See README for deployment guide